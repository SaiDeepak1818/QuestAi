# Groq API Key — get yours free at https://console.groq.com
# Replaces Gemini. Uses llama-3.3-70b-versatile model.
GROQ_API_KEY=gsk_your_groq_api_key_here

# MongoDB connection URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/questai

# JWT secret — change this to a long random string in production
JWT_SECRET=change-this-to-a-random-secret
